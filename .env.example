AUTH_SECRET=""

AUTH_DISCORD_ID=""
AUTH_DISCORD_SECRET=""

AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

DATABASE_URL="postgresql://postgres:password@localhost:5432/reflecto-app"
NEXTAUTH_URL="http://localhost:3000"

HASH_SALT_ROUNDS=10
SKIP_ENV_VALIDATION=false

IMAGEKIT_PUBLIC_KEY=""
IMAGEKIT_PRIVATE_KEY=""
IMAGEKIT_URL_ENDPOINT=""

RESEND_API_KEY=""

# SMTP fallback (optional — used when Resend fails or is in test mode)
SMTP_HOST=""
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER=""
SMTP_PASS=""
EMAIL_FROM="Reflecto <noreply@yourdomain.com>"

# Inngest (optional in dev — required in production)
# Sign up at https://www.inngest.com/ and create an app to get these keys.
# In dev, Inngest runs locally via `npx inngest-cli@latest dev`.
# In production, set these from your Inngest dashboard > App > Keys.
INNGEST_EVENT_KEY=""
INNGEST_SIGNING_KEY=""
